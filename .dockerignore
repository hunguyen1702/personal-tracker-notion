/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/app.yml
/.env

config/settings.local.yml
config/settings/*.local.yml
config/environments/*.local.yml

# git
/.git
/.gitattributes
/.gitignore

# other files
/README.md

# docker
/docker-compose.yml
/.dockerignore
